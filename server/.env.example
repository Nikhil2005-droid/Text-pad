MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/text-pad
PORT=5000
CORS_ORIGIN=
JSON_BODY_LIMIT=1mb
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=240
WORKSPACE_TOKEN_TTL_MS=43200000
GOOGLE_TRANSLITERATION_ENABLED=true
GOOGLE_TRANSLITERATION_PROJECT_ID=your-google-cloud-project-id
GOOGLE_TRANSLITERATION_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\google-service-account.json
GOOGLE_TRANSLITERATION_CREDENTIALS_JSON=
